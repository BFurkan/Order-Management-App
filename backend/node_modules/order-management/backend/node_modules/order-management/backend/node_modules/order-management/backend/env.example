# Backend Environment Variables
# Copy this file to .env and update with your actual values

# Server Configuration
PORT=3007
NODE_ENV=development

# MySQL Database Configuration (Traditional Setup)
# Uncomment if using MySQL instead of Supabase
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=your_username
# DB_PASSWORD=your_password
# DB_NAME=order_tracking

# Supabase Configuration (Recommended)
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS Configuration
CORS_ORIGIN=http://localhost:3008

# Production Example (Current Setup)
# SUPABASE_URL=https://yefrbkudmdakbykrpsfz.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-actual-service-key 